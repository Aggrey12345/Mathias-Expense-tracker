{
  "entities": {
    "User": {
      "title": "User Profile",
      "description": "User specific settings and profile information",
      "type": "object",
      "properties": {
        "uid": { "type": "string" },
        "email": { "type": "string", "format": "email" },
        "displayName": { "type": "string" },
        "photoURL": { "type": "string" },
        "currency": { "type": "string" },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["uid", "currency"]
    },
    "Transaction": {
      "title": "Financial Transaction",
      "description": "An income or expense record",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "userId": { "type": "string" },
        "amount": { "type": "number" },
        "type": { "type": "string", "enum": ["income", "expense"] },
        "category": { "type": "string" },
        "note": { "type": "string" },
        "date": { "type": "string", "format": "date-time" },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["userId", "amount", "type", "category", "date"]
    },
    "Budget": {
      "title": "Category Budget",
      "description": "Spending limit for a specific category",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "userId": { "type": "string" },
        "category": { "type": "string" },
        "limit": { "type": "number" },
        "period": { "type": "string", "enum": ["monthly", "weekly"] },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["userId", "category", "limit", "period"]
    }
  },
  "firestore": {
    "/users/{userId}": {
      "schema": "User",
      "description": "User profile document"
    },
    "/transactions/{transactionId}": {
      "schema": "Transaction",
      "description": "Individual transaction records"
    },
    "/budgets/{budgetId}": {
      "schema": "Budget",
      "description": "User budgets per category"
    }
  }
}
