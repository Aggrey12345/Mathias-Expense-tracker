rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // Default Deny
    match /{document=**} {
      allow read, write: if false;
    }

    // --- Helpers ---
    function isSignedIn() {
      return request.auth != null;
    }

    function isOwner(userId) {
      return isSignedIn() && request.auth.uid == userId;
    }

    function isValidId(id) {
      return id is string && id.size() <= 128 && id.matches('^[a-zA-Z0-9_\\-]+$');
    }

    function incoming() {
      return request.resource.data;
    }

    function existing() {
      return resource.data;
    }

    // --- Validation Blueprints ---
    function isValidUser(data) {
      return data.keys().hasAll(['uid', 'currency', 'createdAt'])
        && data.keys().size() <= 6
        && data.uid == request.auth.uid
        && data.currency is string && data.currency.size() <= 3
        && data.createdAt == request.time
        && (!data.hasAny(['email']) || (data.email is string && data.email.size() <= 100))
        && (!data.hasAny(['displayName']) || (data.displayName is string && data.displayName.size() <= 100))
        && (!data.hasAny(['photoURL']) || (data.photoURL is string && data.photoURL.size() <= 500));
    }

    function isValidTransaction(data) {
      return data.keys().hasAll(['userId', 'amount', 'type', 'category', 'date', 'createdAt'])
        && (data.keys().size() == 6 || (data.keys().size() == 7 && data.hasAny(['note'])))
        && data.userId == request.auth.uid
        && data.amount is number && data.amount >= 0
        && data.type in ['income', 'expense']
        && data.category is string && data.category.size() <= 50
        && data.date is string && data.date.size() <= 50
        && (!data.hasAny(['note']) || (data.note is string && data.note.size() <= 500))
        && data.createdAt == request.time;
    }

    function isValidBudget(data) {
      return data.keys().hasAll(['userId', 'category', 'limit', 'period', 'createdAt'])
        && data.keys().size() == 5
        && data.userId == request.auth.uid
        && data.category is string && data.category.size() <= 50
        && data.limit is number && data.limit >= 0
        && data.period in ['monthly', 'weekly']
        && data.createdAt == request.time;
    }

    // --- Routes ---

    match /users/{userId} {
      allow get: if isOwner(userId);
      allow create: if isOwner(userId) && isValidUser(incoming());
      allow update: if isOwner(userId) 
        && incoming().uid == existing().uid
        && incoming().createdAt == existing().createdAt
        && isValidUser(incoming())
        && (
          incoming().diff(existing()).affectedKeys().hasOnly(['currency', 'email', 'displayName', 'photoURL'])
        );
    }

    match /transactions/{transactionId} {
      allow get: if isSignedIn() && existing().userId == request.auth.uid;
      allow list: if isSignedIn() && resource.data.userId == request.auth.uid;
      allow create: if isSignedIn() && isValidTransaction(incoming());
      allow update: if isSignedIn() 
        && existing().userId == request.auth.uid
        && incoming().userId == existing().userId
        && incoming().createdAt == existing().createdAt
        && isValidTransaction(incoming())
        && (
          incoming().diff(existing()).affectedKeys().hasOnly(['amount', 'type', 'category', 'date', 'note'])
        );
      allow delete: if isSignedIn() && existing().userId == request.auth.uid;
    }

    match /budgets/{budgetId} {
      allow get: if isSignedIn() && existing().userId == request.auth.uid;
      allow list: if isSignedIn() && resource.data.userId == request.auth.uid;
      allow create: if isSignedIn() && isValidBudget(incoming());
      allow update: if isSignedIn()
        && existing().userId == request.auth.uid
        && incoming().userId == existing().userId
        && incoming().createdAt == existing().createdAt
        && isValidBudget(incoming())
        && (
          incoming().diff(existing()).affectedKeys().hasOnly(['limit', 'period', 'category'])
        );
      allow delete: if isSignedIn() && existing().userId == request.auth.uid;
    }
  }
}
